# ─── Banco de dados MySQL ─────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/terapia_acolher

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://seu-dominio.com.br

# ─── Segurança JWT ────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# OBRIGATÓRIO: mínimo 32 caracteres
JWT_SECRET=gere-uma-chave-forte-aqui-minimo-32-caracteres

# ─── Admin ────────────────────────────────────────────────────────────────────
# Senha do painel admin (mínimo 8 caracteres)
# O admin faz login em /admin via tela de senha — nunca vai para o frontend
ADMIN_PASSWORD=troque-esta-senha-admin

# ─── Kiwify ───────────────────────────────────────────────────────────────────
# Token configurado no painel Kiwify → Webhooks → Secret Token
# Quando configurado, todos os webhooks são verificados com timing-safe compare
# Webhook URL: https://seu-dominio.com/api/webhooks/kiwify?token=<KIWIFY_WEBHOOK_TOKEN>
KIWIFY_WEBHOOK_TOKEN=token-configurado-no-painel-kiwify

# ─── ManyChat ─────────────────────────────────────────────────────────────────
# A API key fica no banco (gerenciada via UI em /api/manychat/config)
# Definir aqui apenas como fallback:
MANYCHAT_API_KEY=

# ─── Logs ─────────────────────────────────────────────────────────────────────
# Nível: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Setup ────────────────────────────────────────────────────────────────────
# 1. cp .env.example .env
# 2. Preencha DATABASE_URL, JWT_SECRET, ADMIN_PASSWORD, FRONTEND_URL
# 3. npm run db:push  → criar tabelas
# 4. npm start
#
# Webhook URLs:
#   Kiwify  : POST /api/webhooks/kiwify?token=<KIWIFY_WEBHOOK_TOKEN>
#   ManyChat: POST /api/webhooks/manychat/patient
#             POST /api/receber-paciente  (alias compatível com sistema antigo)
#
# Admin login: POST /api/auth/admin/login  { "password": "<ADMIN_PASSWORD>" }
