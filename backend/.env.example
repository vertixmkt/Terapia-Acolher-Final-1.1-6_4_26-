# ─── Banco de dados MySQL (VPS Hostinger) ────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/terapia_acolher

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Admin auth ───────────────────────────────────────────────────────────────
# Frontend envia: Authorization: Bearer <ADMIN_SECRET>
ADMIN_SECRET=troque-esta-senha

# ─── Kiwify ───────────────────────────────────────────────────────────────────
# Token configurado no painel Kiwify → Webhooks
KIWIFY_WEBHOOK_TOKEN=

# ─── ManyChat ─────────────────────────────────────────────────────────────────
# A API key fica no banco (gerenciada via UI em /api/manychat/config)
# Pode ser definida aqui como fallback apenas:
MANYCHAT_API_KEY=

# ─── Notas ────────────────────────────────────────────────────────────────────
# KIWIFY   : webhook URL → https://seu-dominio.com/api/webhooks/kiwify
# MANYCHAT : External Request → https://seu-dominio.com/api/webhooks/manychat/patient
#            (alias compatível com sistema antigo: /api/receber-paciente)
# Após deploy: npm run db:push → criar tabelas, depois configurar ManyChat via UI
