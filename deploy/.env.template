# ─────────────────────────────────────────────────────────────────────────────
# .env — Backend do App Terapia Acolher
# Copie este arquivo para /var/www/acolher/backend/.env e preencha os valores
# NUNCA commite este arquivo com valores reais
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados MySQL
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=mysql://acolher:SUA_SENHA_AQUI@localhost:3306/terapia_acolher

# Segredo JWT — mínimo 32 caracteres, gere com: openssl rand -hex 32
JWT_SECRET=GERE_COM_openssl_rand_hex_32

# Senha de acesso ao painel admin
ADMIN_PASSWORD=SUA_SENHA_ADMIN_AQUI

# URL do frontend (sem barra no final)
# Em produção: http://76.13.70.229 ou https://seudominio.com
FRONTEND_URL=http://76.13.70.229

# Porta do backend (Nginx faz proxy para esta porta)
PORT=3000

# Ambiente
NODE_ENV=production

# Token de verificação do webhook Kiwify (opcional)
# KIWIFY_WEBHOOK_TOKEN=

# Nível de log em produção
LOG_LEVEL=info
